---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile, certifications } from "../data/profile";
import { clinicalExperiences } from "../data/clinical";
const base = import.meta.env.BASE_URL;
const resumePath = base + profile.resume;
---

<BaseLayout title="Résumé | Caroline Thomas" description="Education, clinical preparation, certifications, and experience for Caroline Thomas, BSN candidate.">
  <section class="resume-hero">
    <div class="shell resume-hero-grid">
      <div data-reveal>
        <p class="eyebrow"><span>Résumé</span> Current profile</p>
        <h1>Prepared to<br /><em>keep learning.</em></h1>
      </div>
      <div class="resume-hero-side" data-reveal>
        <p>{profile.positioning}</p>
        <div class="hero-actions">
          <a class="button button-primary" href={resumePath} download>Download PDF <span aria-hidden="true">↓</span></a>
          <a class="button button-quiet" href={"mailto:" + profile.email}>Email Caroline <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="resume-content section">
    <div class="shell resume-layout">
      <aside class="resume-sidebar" data-reveal>
        <div>
          <span>Location</span>
          <strong>{profile.location}</strong>
        </div>
        <div>
          <span>Expected graduation</span>
          <strong>{profile.graduation}</strong>
        </div>
        <div>
          <span>Contact</span>
          <a href={"mailto:" + profile.email}>{profile.email}</a>
          <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn ↗</a>
        </div>
      </aside>

      <div class="resume-sections">
        <section class="resume-block" data-reveal>
          <span class="resume-section-number">01</span>
          <div>
            <h2>Education</h2>
            <article class="resume-entry">
              <div>
                <h3>Bachelor of Science in Nursing</h3>
                <p>{profile.school} · Lynchburg, Virginia</p>
                <p>{profile.minor} · {profile.gpa} · Nursing Student Association</p>
              </div>
              <strong>Expected {profile.graduation}</strong>
            </article>
          </div>
        </section>

        <section class="resume-block" data-reveal>
          <span class="resume-section-number">02</span>
          <div>
            <h2>Clinical preparation</h2>
            <article class="resume-entry">
              <div>
                <h3>Student Nurse</h3>
                <p>Liberty University School of Nursing</p>
                <p>499+ supervised clinical hours anticipated before graduation.</p>
              </div>
              <strong>2025—2026</strong>
            </article>
            <div class="resume-rotation-list">
              {clinicalExperiences.map((experience) => (
                <div><span>{experience.specialty}</span><small>{experience.site}</small></div>
              ))}
              <div><span>Triage · OR · Pediatrics</span><small>Jesse-Kay Hospital, Nairobi</small></div>
            </div>
          </div>
        </section>

        <section class="resume-block" data-reveal>
          <span class="resume-section-number">03</span>
          <div>
            <h2>Certifications</h2>
            <div class="resume-cert-list">
              {certifications.map((certification) => <p>{certification}</p>)}
            </div>
          </div>
        </section>

        <section class="resume-block" data-reveal>
          <span class="resume-section-number">04</span>
          <div>
            <h2>Additional experience</h2>
            <article class="resume-entry">
              <div>
                <h3>Server · More Better Restaurant</h3>
                <p>Fast-paced service, prioritization, teamwork, and clear communication.</p>
              </div>
              <strong>2021—Present</strong>
            </article>
            <article class="resume-entry">
              <div>
                <h3>Volunteer · Impact Africa</h3>
                <p>Community-centered service experience in Johannesburg, South Africa.</p>
              </div>
              <strong>2022</strong>
            </article>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
