---
const base = import.meta.env.BASE_URL;
const navItems = [
  { href: base, label: "Home" },
  { href: `${base}resume`, label: "Resume" },
  { href: `${base}clinical-experience`, label: "Clinical" },
  { href: `${base}portfolio`, label: "Portfolio" },
  { href: `${base}contact`, label: "Contact" }
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-50 border-b border-white/50 bg-white/54 backdrop-blur-2xl">
  <nav class="container-premium flex min-h-20 items-center justify-between gap-6" aria-label="Primary navigation">
    <a href={base} class="group flex items-center gap-3 font-bold text-navy" aria-label="Caroline Thomas home">
      <span class="grid size-10 place-items-center rounded-2xl bg-navy text-white shadow-glow">CT</span>
      <span class="hidden leading-tight sm:block">
        Caroline Thomas
        <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-teal">Nursing Portfolio</span>
      </span>
    </a>
    <div class="flex items-center gap-1 overflow-x-auto rounded-2xl border border-white/80 bg-white/58 p-1 shadow-sm backdrop-blur-2xl">
      {navItems.map((item) => {
        const cleanHref = item.href.replace(/\/$/, "") || "/";
        const active = currentPath === cleanHref;
        return (
          <a
            href={item.href}
            aria-current={active ? "page" : undefined}
            class:list={[
              "whitespace-nowrap rounded-xl px-3.5 py-2 text-sm font-semibold transition",
              active ? "bg-navy text-white shadow-sm" : "text-ink/75 hover:bg-white/70 hover:text-navy"
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </div>
  </nav>
</header>
