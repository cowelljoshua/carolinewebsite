---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact | Caroline Thomas">
  <section class="standalone-contact">
    <div class="shell contact-panel">
      <div class="contact-kicker"><span class="status-dot"></span> Available for 2026 new-grad conversations</div>
      <h1>Let’s start with<br /><em>an introduction.</em></h1>
      <p>{profile.location} · {profile.title}</p>
      <div class="contact-actions">
        <a class="button button-white" href={"mailto:" + profile.email}>{profile.email} <span aria-hidden="true">↗</span></a>
        <a class="contact-text-link" href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn ↗</a>
        <a class="contact-text-link" href={base + profile.resume}>Résumé ↓</a>
      </div>
      <span class="contact-monogram" aria-hidden="true">CT</span>
    </div>
  </section>
</BaseLayout>
