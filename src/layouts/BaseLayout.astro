---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Navbar from "../components/react/Navbar";
import Footer from "../components/Footer.astro";

const {
  title = "Caroline Thomas | Senior Nursing Student",
  description = "Premium nursing portfolio for Caroline Thomas, senior nursing student focused on emergency nursing, service, and future CRNA preparation."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#06111d" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="aurora" aria-hidden="true"></div>
    <Navbar currentPath={Astro.url.pathname} client:load />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import "../scripts/animations";
    </script>
  </body>
</html>
