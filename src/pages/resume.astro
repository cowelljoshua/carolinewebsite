---
import BaseLayout from "../layouts/BaseLayout.astro";
const resumePath = `${import.meta.env.BASE_URL}documents/Caroline-Thomas-Senior-Nursing-Resume.pdf`;
---

<BaseLayout title="Resume | Caroline Thomas">
  <section class="py-14 md:py-20">
    <div class="container-premium">
      <div class="mb-8 flex justify-center">
        <a
          href={resumePath}
          download
          class="inline-flex items-center gap-3 rounded-2xl bg-black px-6 py-3 text-sm font-bold text-white shadow-premium transition hover:-translate-y-0.5 hover:bg-navy"
        >
          <span aria-hidden="true">↓</span>
          Download PDF Resume
        </a>
      </div>

      <article class="mx-auto max-w-4xl bg-white px-8 py-9 text-[0.88rem] leading-6 text-slate-900 shadow-premium ring-1 ring-slate-200 md:px-12 md:py-12">
        <header class="text-center">
          <h1 class="text-3xl font-extrabold tracking-tight text-black">Caroline Thomas</h1>
          <p class="mt-3 text-sm text-slate-700">
            Round Hill, VA <span class="mx-2 text-gold">|</span>
            <a class="hover:text-teal" href="mailto:cthomas330@liberty.edu">cthomas330@liberty.edu</a>
            <span class="mx-2 text-gold">|</span> (571) 420-2500
          </p>
        </header>

        <div class="mt-7 border-t-2 border-black"></div>

        <section class="resume-section">
          <h2>Education</h2>
          <div class="resume-row">
            <div>
              <h3>Bachelor of Science in Nursing</h3>
              <p><em>Liberty University, Lynchburg, VA</em></p>
              <p>Minor: Psychology | GPA: 3.66 | Nursing Student Association</p>
            </div>
            <p class="resume-date">Expected December 2026</p>
          </div>
        </section>

        <section class="resume-section">
          <h2>Summary</h2>
          <p>Senior BSN student seeking new graduate emergency nursing opportunities. Focused on calm patient-centered care, strong clinical judgment, and growth toward future critical care and CRNA preparation.</p>
        </section>

        <section class="resume-section">
          <h2>Licenses and Certifications</h2>
          <div class="grid gap-2 md:grid-cols-2">
            <p><strong>Basic Life Support</strong>, American Heart Association</p>
            <p class="md:text-right">February 2025</p>
            <p><strong>Mental Health First Aid</strong>, National Council for Mental Wellbeing</p>
            <p class="md:text-right">May 2026</p>
            <p><strong>Workplace Violence Prevention</strong>, NIOSH</p>
            <p class="md:text-right">May 2026</p>
            <p><strong>NCLEX</strong></p>
            <p class="md:text-right">Anticipated after graduation</p>
          </div>
        </section>

        <section class="resume-section">
          <h2>Relevant Clinical Experience</h2>
          <div class="resume-row">
            <div>
              <h3>Student Nurse, Liberty University School of Nursing</h3>
              <p><em>Lynchburg, VA</em></p>
            </div>
            <p class="resume-date">January 2025 - December 2026</p>
          </div>
          <ul>
            <li>Conduct and document comprehensive head-to-toe nursing assessments in supervised clinical settings.</li>
            <li>Develop clinical judgment across emergency, medical, neuro-intermediate, maternal-child, and community settings.</li>
            <li>Anticipating 499+ clinical hours before graduation.</li>
          </ul>
          <div class="mt-4 grid gap-x-8 gap-y-2 text-sm md:grid-cols-2">
            <p><strong>Lynchburg General Hospital:</strong> Emergency Department, Neuro-Intermediate Care, Diabetic Renal, General Medical</p>
            <p><strong>Virginia Baptist Hospital:</strong> Labor and Delivery, Mother Baby</p>
            <p><strong>Community Health Nursing:</strong> Lynchburg, VA</p>
            <p><strong>Jesse-Kay Hospital:</strong> Nairobi, Kenya - Triage, OR, Pediatrics</p>
          </div>
        </section>

        <section class="resume-section">
          <h2>Additional Experience</h2>
          <div class="resume-row">
            <div>
              <h3>Waitress, More Better Restaurant</h3>
              <p><em>Round Hill, VA</em></p>
            </div>
            <p class="resume-date">June 2021 - Present</p>
          </div>
          <ul>
            <li>Manage time in a fast-paced environment while prioritizing customer needs and team communication.</li>
            <li>Build professionalism, composure, and service habits that translate well to patient-facing care.</li>
          </ul>
        </section>

        <section class="resume-section">
          <h2>Community Engagement</h2>
          <div class="resume-row">
            <div>
              <h3>Volunteer, Impact Africa</h3>
              <p><em>Johannesburg, South Africa</em></p>
            </div>
            <p class="resume-date">July 2022</p>
          </div>
          <p>Service experience focused on cultural humility, adaptability, and community-centered support.</p>
        </section>
      </article>
    </div>
  </section>
</BaseLayout>
