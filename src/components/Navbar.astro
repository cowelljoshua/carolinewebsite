---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.props.currentPath.replace(/\/$/, "") || "/";
const homePath = base.replace(/\/$/, "") || "/";
const onHome = currentPath === homePath;
const sectionLink = (hash: string) => onHome ? hash : base + hash;

const navItems = [
  { href: sectionLink("#overview"), label: "Overview" },
  { href: sectionLink("#experience"), label: "Experience" },
  { href: base + "portfolio", label: "Work" },
  { href: base + "resume", label: "Resume" },
  { href: sectionLink("#contact"), label: "Contact" },
];
---

<header class="site-header">
  <nav class="site-nav shell" aria-label="Primary navigation">
    <a href={base} class="brand" aria-label="Caroline Thomas home">
      <span class="brand-mark" aria-hidden="true">CT</span>
      <span class="brand-copy">
        <strong>Caroline Thomas</strong>
        <small>BSN Candidate</small>
      </span>
    </a>

    <div class="nav-links">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={
            (item.label === "Work" && currentPath.includes("/portfolio")) ||
            (item.label === "Resume" && currentPath.includes("/resume"))
              ? "page"
              : undefined
          }
        >
          {item.label}
        </a>
      ))}
    </div>

    <a class="nav-availability" href="mailto:cthomas330@liberty.edu">
      <span aria-hidden="true"></span>
      Open to new-grad roles
    </a>
  </nav>
</header>
