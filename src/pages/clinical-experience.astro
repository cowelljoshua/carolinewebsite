---
import BaseLayout from "../layouts/BaseLayout.astro";
import { clinicalExperiences, globalHealth } from "../data/clinical";
---

<BaseLayout title="Clinical Experience | Caroline Thomas">
  <section class="pb-8 pt-12 md:pb-10 md:pt-16">
    <div class="container-premium">
      <p class="eyebrow reveal">Clinical Experience</p>
      <h1 class="reveal mt-4 max-w-4xl text-4xl font-bold leading-tight tracking-tight text-white md:text-6xl">Clinical Experience</h1>
      <p class="reveal mt-4 max-w-2xl text-base leading-7 text-slate-300 md:text-lg">High-level rotation snapshot with details available on request.</p>
    </div>
  </section>
  <section class="pb-10">
    <div class="container-premium grid gap-4 lg:grid-cols-2">
      {clinicalExperiences.map((item) => (
        <article class="reveal glass grid gap-4 rounded-[1.5rem] p-5">
          <div>
            <p class="eyebrow">{item.specialty}</p>
            <h2 class="mt-2 text-2xl font-bold tracking-tight text-navy">{item.site}</h2>
            <p class="mt-2 text-sm leading-6 text-ink/64">{item.skills.slice(0, 3).join(" / ")}</p>
          </div>
          <p class="w-fit rounded-2xl border border-white/10 bg-white/10 px-4 py-2 text-sm font-bold text-teal">Hours: {item.hours}</p>
        </article>
      ))}
    </div>
  </section>
  <section class="pb-16 md:pb-20">
    <div class="container-premium liquid-glass grid gap-6 rounded-[2rem] p-7 md:grid-cols-[.8fr_1.2fr] md:p-9">
      <div>
        <p class="eyebrow reveal">Global Health</p>
        <h2 class="reveal mt-3 text-3xl font-bold tracking-tight text-navy">{globalHealth.location}</h2>
      </div>
      <p class="reveal leading-7 text-ink/68">Service-focused exposure in triage, operating room, and pediatrics. Emphasis: cultural humility, adaptable communication, and dignity-centered care.</p>
    </div>
  </section>
</BaseLayout>
