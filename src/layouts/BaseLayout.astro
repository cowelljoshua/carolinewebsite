---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Caroline Thomas | BSN Candidate",
  description = "Caroline Thomas is a BSN candidate at Liberty University preparing for new-graduate RN opportunities through broad clinical experience, service, and thoughtful patient education.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const socialImage = new URL(base + "og.png", Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f4f7f8" />
    <link rel="icon" type="image/svg+xml" href={base + "favicon.svg"} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Navbar currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script>
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const reveal = () => {
        const nodes = document.querySelectorAll<HTMLElement>("[data-reveal]");
        if (reduceMotion) {
          nodes.forEach((node) => node.classList.add("is-visible"));
          return;
        }
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -5% 0px" },
        );
        nodes.forEach((node) => observer.observe(node));
      };

      document.addEventListener("astro:page-load", reveal);
      reveal();
    </script>
  </body>
</html>
