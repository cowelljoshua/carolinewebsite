---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import StatCounters from "../components/react/StatCounters";
import HeroTitle from "../components/react/HeroTitle";
import { stats } from "../data/stats";

const highlights = [
  ["ED Focus", "New graduate emergency nursing."],
  ["BSN 2026", "Liberty University, psychology minor."],
  ["Global Health", "Kenya clinical exposure and service."],
  ["Next Goal", "Critical care growth and future CRNA path."]
];
---

<BaseLayout title="Caroline Thomas | Senior Nursing Student Portfolio">
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container-premium grid items-center gap-8 lg:grid-cols-[1.05fr_.95fr]">
      <div class="reveal liquid-glass rounded-[2rem] p-7 md:p-10">
        <p class="eyebrow">Emergency Nursing Portfolio</p>
        <HeroTitle client:load />
        <p class="mt-6 max-w-xl text-lg leading-8 text-ink/70">
          BSN candidate focused on emergency nursing, calm patient care, and strong clinical judgment.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <ButtonLink href="/resume" label="Resume" />
          <ButtonLink href="/portfolio" label="View Portfolio" variant="secondary" />
          <ButtonLink href="/contact" label="Contact" variant="secondary" />
        </div>
      </div>
      <figure class="hero-float reveal group relative aspect-[3/4] overflow-hidden rounded-[2rem] border border-white/14 bg-white/[0.06] shadow-premium backdrop-blur-2xl">
        <img src="/assets/caroline-kenya-portrait.webp" alt="Caroline Thomas during a clinical trip to Kenya" class="h-full w-full object-cover opacity-90 transition duration-500 group-hover:scale-[1.03] group-hover:opacity-100" loading="eager" />
        <figcaption class="pointer-events-none absolute inset-x-5 bottom-5 translate-y-3 rounded-2xl border border-white/14 bg-[#06111d]/72 px-4 py-3 text-center text-sm font-bold text-white opacity-0 shadow-premium backdrop-blur-xl transition duration-300 group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:translate-y-0 group-focus-within:opacity-100">
          Clinical trip to Kenya, Africa
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="pb-12">
    <div class="container-premium">
      <StatCounters stats={stats} client:load />
    </div>
  </section>

  <section class="section-pad pt-8">
    <div class="container-premium grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {highlights.map(([title, copy]) => (
        <article class="reveal glass rounded-[1.5rem] p-5">
          <div class="mb-4 h-1 w-10 rounded-full bg-gold"></div>
          <h3 class="text-xl font-bold text-navy">{title}</h3>
          <p class="mt-2 text-sm leading-6 text-ink/65">{copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="pb-16 md:pb-24">
    <div class="container-premium liquid-glass grid gap-6 rounded-[2rem] p-7 md:grid-cols-[1fr_auto] md:items-center md:p-9">
      <div>
        <p class="eyebrow">Recruiter Snapshot</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-navy">Simple, focused, ready to discuss fit.</h2>
        <p class="mt-3 max-w-2xl leading-7 text-ink/66">Resume, clinical background, and selected projects are available in the top navigation. No patient-identifying information is included.</p>
      </div>
      <ButtonLink href="/contact" label="Contact Caroline" />
    </div>
  </section>
</BaseLayout>
