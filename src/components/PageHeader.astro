---
const { eyebrow, title, copy } = Astro.props;
---

<section class="section-pad pb-12">
  <div class="container-premium max-w-4xl">
    <p class="eyebrow reveal">{eyebrow}</p>
    <h1 class="reveal mt-4 text-4xl font-bold leading-tight tracking-tight text-white md:text-6xl">{title}</h1>
    <p class="reveal mt-5 max-w-2xl text-base leading-7 text-slate-300 md:text-lg">{copy}</p>
  </div>
</section>
