---
import BaseLayout from "../layouts/BaseLayout.astro";
import { clinicalExperiences } from "../data/clinical";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Clinical Experience | Caroline Thomas">
  <section class="page-hero compact-page-hero">
    <div class="shell">
      <p class="eyebrow"><span>Clinical</span> Supervised preparation</p>
      <div class="page-title-grid">
        <h1>Experience<br /><em>in progress.</em></h1>
        <div class="page-intro">
          <p>Rotations across acute, specialty, maternal-child, and community settings.</p>
          <a class="button button-primary" href={base + "#experience"}>View the overview <span aria-hidden="true">→</span></a>
        </div>
      </div>
      <div class="simple-clinical-list">
        {clinicalExperiences.map((item, index) => (
          <article>
            <span>0{index + 1}</span>
            <div><h2>{item.specialty}</h2><p>{item.site}</p></div>
            <small>In progress</small>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
